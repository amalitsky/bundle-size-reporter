{
  "name": "@bundle-size-reporter/cli",
  "version": "3.0.0",
  "description": "Bundle Size Reporter CLI",
  "bin": {
    "bsr": "dist/index.mjs"
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "tsc-check": "tsc --noEmit",
    "prepack": "npm run build",
    "prebuild": "rm -rf ./dist",
    "build": "tsc",
    "postbuild": "node ./add-shebang-to-cli-dist.mjs",
    "pretest-e2e": "rm -rf e2e-tests/artifacts && mkdir e2e-tests/artifacts && npm run build",
    "test": "npm run test-unit && npm run test-e2e",
    "test-e2e": "node --test e2e-tests/*.test.mts",
    "test-e2e:update-snapshots": "node --test --test-update-snapshots e2e-tests/*.test.mts",
    "test-unit": "node --test unit-tests/*.test.mts",
    "test-unit:update-snapshots": "node --test --test-update-snapshots unit-tests/*.test.mts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amalitsky/bundle-size-reporter.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "private": false,
  "keywords": [
    "CLI",
    "CI tools",
    "devtools",
    "UI",
    "SPA",
    "web",
    "bundle",
    "load size",
    "bundle size",
    "reporter",
    "size",
    "automation",
    "tools",
    "tooling"
  ],
  "author": "Alex Malitsky",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/amalitsky/bundle-size-reporter/issues"
  },
  "homepage": "https://github.com/amalitsky/bundle-size-reporter#readme",
  "dependencies": {
    "@bundle-size-reporter/core": "^2.0.0",
    "glob": "^13.0.6",
    "gzip-size": "^7.0.0",
    "lodash-es": "^4.18.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/yargs": "^17.0.35"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
